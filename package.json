{
  "name": "stealthy",
  "private": true,
  "version": "1.0.0",
  "description": "AI Meeting Assistant Overlay - Undetectable, Supports Multiple LLM Providers",
  "author": "Stealthy",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "electron .",
    "start": "concurrently \"npm run dev\" \"npm run electron\"",
    "dist-electron": "vite build && electron-builder",
    "dist-win": "vite build && electron-builder --win",
    "dist-linux": "vite build && electron-builder --linux"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "openai": "^4.24.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.8"
  },
  "build": {
    "appId": "com.stealthy.app",
    "productName": "Stealthy",
    "copyright": "Copyright © 2025 Stealthy",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/main.cjs",
      "electron/preload.cjs",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        }
      ],
      "category": "Utility",
      "description": "Stealthy - AI Meeting Assistant Overlay"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}